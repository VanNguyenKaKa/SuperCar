@page
@model HyperCar.Web.Pages.Checkout.IndexModel
@{
    ViewData["Title"] = "Checkout";
}

<section class="pt-5 mt-5">
    <div class="container py-4">
        <h2 class="section-title mb-4"><i class="fas fa-credit-card me-2"></i>Check<span class="text-accent">out</span></h2>

        @if (Model.Cart?.Items?.Any() == true)
        {
            <form method="post" id="checkoutForm">
                <div class="row g-4">
                    <div class="col-lg-7">
                        <!-- Shipping Information -->
                        <div class="card bg-dark border-secondary mb-4">
                            <div class="card-header"><h5 class="mb-0"><i class="fas fa-shipping-fast me-2"></i>Shipping Information</h5></div>
                            <div class="card-body">
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <label class="form-label">Full Name <span class="text-danger">*</span></label>
                                        <input type="text" name="OrderDto.ReceiverName" class="form-control" required placeholder="Nguyễn Văn A" />
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">Phone Number <span class="text-danger">*</span></label>
                                        <input type="text" name="OrderDto.ReceiverPhone" class="form-control" required placeholder="0901234567" />
                                    </div>

                                    <!-- Province Dropdown -->
                                    <div class="col-md-4">
                                        <label class="form-label">Tỉnh / Thành phố <span class="text-danger">*</span></label>
                                        <select name="OrderDto.ProvinceId" id="provinceSelect" class="form-select" required>
                                            <option value="">-- Chọn Tỉnh --</option>
                                            @foreach (var p in Model.Provinces)
                                            {
                                                <option value="@p.ProvinceId">@p.ProvinceName</option>
                                            }
                                        </select>
                                    </div>

                                    <!-- District Dropdown -->
                                    <div class="col-md-4">
                                        <label class="form-label">Quận / Huyện <span class="text-danger">*</span></label>
                                        <select name="OrderDto.DistrictId" id="districtSelect" class="form-select" required disabled>
                                            <option value="">-- Chọn Quận --</option>
                                        </select>
                                    </div>

                                    <!-- Ward Dropdown -->
                                    <div class="col-md-4">
                                        <label class="form-label">Phường / Xã <span class="text-danger">*</span></label>
                                        <select name="OrderDto.WardCode" id="wardSelect" class="form-select" required disabled>
                                            <option value="">-- Chọn Phường --</option>
                                        </select>
                                    </div>

                                    <!-- Street Address -->
                                    <div class="col-12">
                                        <label class="form-label">Địa chỉ chi tiết <span class="text-danger">*</span></label>
                                        <input type="text" name="OrderDto.ShippingAddress" class="form-control" required placeholder="Số nhà, tên đường..." />
                                    </div>

                                    <!-- Note -->
                                    <div class="col-12">
                                        <label class="form-label">Ghi chú</label>
                                        <textarea name="OrderDto.Note" class="form-control" rows="2" placeholder="Ghi chú cho đơn hàng (tùy chọn)..."></textarea>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Shipping Speed Tiers -->
                        <div class="card bg-dark border-secondary mb-4">
                            <div class="card-header"><h5 class="mb-0"><i class="fas fa-truck me-2"></i>Phương thức vận chuyển</h5></div>
                            <div class="card-body">
                                <div class="row g-3" id="shippingTiers">
                                    <!-- Standard -->
                                    <div class="col-12">
                                        <label class="shipping-tier-card active" data-tier="standard">
                                            <input type="radio" name="OrderDto.ShippingTier" value="standard" checked class="d-none tier-radio" />
                                            <div class="d-flex align-items-center justify-content-between p-3 rounded-3 border tier-border">
                                                <div class="d-flex align-items-center gap-3">
                                                    <div class="tier-icon">
                                                        <i class="fas fa-box fa-lg text-info"></i>
                                                    </div>
                                                    <div>
                                                        <h6 class="mb-0">Tiêu chuẩn</h6>
                                                        <small class="text-muted">5-7 ngày làm việc</small>
                                                    </div>
                                                </div>
                                                <div class="text-end">
                                                    <span class="tier-fee badge bg-secondary" id="feeStandard">--</span>
                                                </div>
                                            </div>
                                        </label>
                                    </div>
                                    <!-- Express -->
                                    <div class="col-12">
                                        <label class="shipping-tier-card" data-tier="express">
                                            <input type="radio" name="OrderDto.ShippingTier" value="express" class="d-none tier-radio" />
                                            <div class="d-flex align-items-center justify-content-between p-3 rounded-3 border tier-border">
                                                <div class="d-flex align-items-center gap-3">
                                                    <div class="tier-icon">
                                                        <i class="fas fa-shipping-fast fa-lg text-warning"></i>
                                                    </div>
                                                    <div>
                                                        <h6 class="mb-0">Nhanh</h6>
                                                        <small class="text-muted">2-3 ngày làm việc</small>
                                                    </div>
                                                </div>
                                                <div class="text-end">
                                                    <span class="tier-fee badge bg-secondary" id="feeExpress">--</span>
                                                </div>
                                            </div>
                                        </label>
                                    </div>
                                    <!-- Hỏa tốc -->
                                    <div class="col-12">
                                        <label class="shipping-tier-card" data-tier="hoatoc">
                                            <input type="radio" name="OrderDto.ShippingTier" value="hoatoc" class="d-none tier-radio" />
                                            <div class="d-flex align-items-center justify-content-between p-3 rounded-3 border tier-border">
                                                <div class="d-flex align-items-center gap-3">
                                                    <div class="tier-icon">
                                                        <i class="fas fa-bolt fa-lg text-danger"></i>
                                                    </div>
                                                    <div>
                                                        <h6 class="mb-0">Hỏa tốc</h6>
                                                        <small class="text-muted">1-2 ngày làm việc</small>
                                                    </div>
                                                </div>
                                                <div class="text-end">
                                                    <span class="tier-fee badge bg-secondary" id="feeHoatoc">--</span>
                                                </div>
                                            </div>
                                        </label>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Payment Method -->
                        <div class="card bg-dark border-secondary">
                            <div class="card-header"><h5 class="mb-0"><i class="fas fa-wallet me-2"></i>Phương thức thanh toán</h5></div>
                            <div class="card-body">
                                <div class="form-check mb-2">
                                    <input class="form-check-input" type="radio" name="paymentMethod" value="VNPay" id="vnpay" checked />
                                    <label class="form-check-label" for="vnpay">
                                        <i class="fas fa-university me-1"></i>VNPay (Bank Transfer / Cards)
                                    </label>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Order Summary -->
                    <div class="col-lg-5">
                        <div class="card bg-dark border-secondary sticky-top" style="top: 100px;">
                            <div class="card-header"><h5 class="mb-0"><i class="fas fa-receipt me-2"></i>Tóm tắt đơn hàng</h5></div>
                            <div class="card-body">
                                @foreach (var item in Model.Cart.Items)
                                {
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <div class="d-flex align-items-center gap-2">
                                            @if (!string.IsNullOrEmpty(item.CarImage))
                                            {
                                                <img src="@item.CarImage" alt="" style="width: 40px; height: 28px; object-fit: cover; border-radius: 4px;" />
                                            }
                                            <span class="small">@item.CarName <span class="text-muted">x@item.Quantity</span></span>
                                        </div>
                                        <strong>@item.Subtotal.ToString("N0") ₫</strong>
                                    </div>
                                }
                                <hr class="border-secondary" />
                                <div class="d-flex justify-content-between mb-2">
                                    <span>Tạm tính</span>
                                    <strong>@Model.Cart.TotalAmount.ToString("N0") ₫</strong>
                                </div>
                                <div class="d-flex justify-content-between mb-2">
                                    <span>Phí vận chuyển</span>
                                    <span id="shippingTotal" class="text-muted">Chọn địa chỉ...</span>
                                </div>
                                <div class="d-flex justify-content-between mb-2" id="tierNameRow" style="display: none !important;">
                                    <span class="small text-muted">Giao hàng</span>
                                    <span id="tierNameDisplay" class="small text-accent"></span>
                                </div>
                                <hr class="border-secondary" />
                                <div class="d-flex justify-content-between mb-3">
                                    <h5 class="mb-0">Tổng cộng</h5>
                                    <h5 class="text-accent mb-0" id="grandTotal">@Model.Cart.TotalAmount.ToString("N0") ₫</h5>
                                </div>
                                <input type="hidden" id="subtotalValue" value="@Model.Cart.TotalAmount" />
                                <button type="submit" class="btn btn-accent w-100 btn-lg" id="placeOrderBtn">
                                    <i class="fas fa-lock me-2"></i>Đặt hàng & Thanh toán
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </form>
        }
        else
        {
            <div class="text-center py-5">
                <i class="fas fa-shopping-cart fa-4x text-muted mb-3"></i>
                <h3>Giỏ hàng trống</h3>
                <a href="/Cars" class="btn btn-accent mt-3"><i class="fas fa-car me-1"></i>Tiếp tục mua sắm</a>
            </div>
        }
    </div>
</section>

@section Scripts {
    <script src="~/js/checkout.js" asp-append-version="true"></script>
}
