@page
@model HyperCar.Web.Pages.PrivacyModel
@{
    ViewData["Title"] = "Privacy Policy";
}

<section class="pt-5 mt-5">
    <div class="container py-4">
        <h2 class="section-title mb-4">Privacy <span class="text-accent">Policy</span></h2>
        <div class="card bg-dark border-secondary">
            <div class="card-body">
                <p>HyperCar respects your privacy. This policy explains how we collect, use, and protect your personal information when you use our platform.</p>
                <h5 class="text-accent mt-4">Data We Collect</h5>
                <p class="text-muted">We collect information you provide during registration, orders, and interactions with our AI assistant.</p>
                <h5 class="text-accent mt-4">Contact Us</h5>
                <p class="text-muted">Questions? Reach us at <a href="mailto:privacy@hypercar.vn" class="text-accent">privacy@hypercar.vn</a></p>
            </div>
        </div>
    </div>
</section>
