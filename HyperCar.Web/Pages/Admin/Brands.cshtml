@page
@model HyperCar.Web.Pages.Admin.BrandsModel
@{
    ViewData["Title"] = "Quản lý hãng xe";
}

<section class="pt-5 mt-5">
    <div class="container-fluid py-4 px-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="section-title mb-0"><i class="fas fa-tags me-2"></i>Quản lý <span class="text-accent">Hãng xe</span></h2>
            <button class="btn btn-accent" data-bs-toggle="modal" data-bs-target="#brandModal" onclick="openAddBrand()">
                <i class="fas fa-plus me-1"></i>Thêm hãng
            </button>
        </div>

        <div class="row g-4">
            @if (Model.Brands?.Any() == true)
            {
                @foreach (var brand in Model.Brands)
                {
                    <div class="col-md-4 col-lg-3">
                        <div class="card bg-dark border-secondary h-100">
                            <div class="card-body text-center">
                                @if (!string.IsNullOrEmpty(brand.Logo))
                                {
                                    <img src="@brand.Logo" class="mb-3" style="width:60px;height:60px;object-fit:contain;" alt="@brand.Name" />
                                }
                                else
                                {
                                    <div class="mb-3"><i class="fas fa-building fa-3x text-accent"></i></div>
                                }
                                <h5 class="card-title">@brand.Name</h5>
                                <small class="text-muted"><i class="fas fa-globe me-1"></i>@brand.Country</small>
                                <small class="text-muted"><i class="fas fa-car me-1"></i>@brand.CarCount xe</small>
                                <p class="text-muted small">@(brand.Description?.Length > 80 ? brand.Description.Substring(0, 80) + "..." : brand.Description)</p>
                            </div>
                            <div class="card-footer border-secondary d-flex gap-2">
                                <button class="btn btn-sm btn-outline-warning flex-fill" onclick="editBrand(@brand.Id, '@brand.Name.Replace("'","\\'")','@brand.Country?.Replace("'","\\'")','@brand.Logo','@brand.Description?.Replace("'","\\'").Replace("\n","")')">
                                    <i class="fas fa-edit me-1"></i>Edit
                                </button>
                                <form method="post" asp-page-handler="Delete" class="flex-fill" onsubmit="return confirm('Xóa hãng này?')">
                                    <input type="hidden" name="id" value="@brand.Id" />
                                    <button class="btn btn-sm btn-outline-danger w-100"><i class="fas fa-trash me-1"></i>Delete</button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center text-muted py-5">No brands found.</div>
            }
        </div>
    </div>
</section>

<!-- Brand Modal -->
<div class="modal fade" id="brandModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content bg-dark border-secondary">
            <div class="modal-header border-secondary">
                <h5 class="modal-title" id="brandModalLabel"><i class="fas fa-tags me-2"></i>Thêm hãng</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form id="brandForm" method="post" asp-page-handler="Create" enctype="multipart/form-data">
                <div class="modal-body">
                    <input type="hidden" id="brandEditId" name="EditId" />
                    <input type="hidden" id="brandLogoUrl" name="BrandInput.Logo" />
                    <div class="mb-3">
                        <label class="form-label">Tên hãng</label>
                        <input name="BrandInput.Name" id="brandName" class="form-control bg-dark text-light border-secondary" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Quốc gia</label>
                        <input name="BrandInput.Country" id="brandCountry" class="form-control bg-dark text-light border-secondary" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label"><i class="fas fa-cloud-upload-alt me-1"></i>Logo Image</label>
                        <input type="file" name="BrandLogo" id="brandLogoFile" accept="image/*" class="form-control bg-dark text-light border-secondary" onchange="previewBrandLogo(this)" />
                        <small class="text-muted">Upload logo to Cloudinary. Leave empty to keep existing logo when editing.</small>
                    </div>
                    <div class="mb-3" id="brandLogoPreviewContainer" style="display:none;">
                        <label class="form-label">Logo</label>
                        <div>
                            <img id="brandLogoPreview" class="rounded" style="max-width:100px;max-height:100px;object-fit:contain;" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Mô tả</label>
                        <textarea name="BrandInput.Description" id="brandDesc" rows="3" class="form-control bg-dark text-light border-secondary"></textarea>
                    </div>
                </div>
                <div class="modal-footer border-secondary">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-accent" id="brandSubmitBtn">Tạo hãng</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function resetBrandForm() {
            document.getElementById('brandModalTitle').textContent = '➕ Add Brand';
            document.getElementById('brandSubmitBtn').textContent = 'Create Brand';
            document.getElementById('brandForm').action = '?handler=Create';
            document.getElementById('brandEditId').value = '';
            document.getElementById('brandLogoUrl').value = '';
            document.getElementById('brandName').value = '';
            document.getElementById('brandCountry').value = '';
            document.getElementById('brandLogoFile').value = '';
            document.getElementById('brandDesc').value = '';
            document.getElementById('brandLogoPreviewContainer').style.display = 'none';
        }

        function editBrand(id, name, country, logo, desc) {
            document.getElementById('brandModalTitle').textContent = '✏️ Edit Brand';
            document.getElementById('brandSubmitBtn').textContent = 'Update Brand';
            document.getElementById('brandForm').action = '?handler=Edit';
            document.getElementById('brandEditId').value = id;
            document.getElementById('brandLogoUrl').value = logo || '';
            document.getElementById('brandName').value = name;
            document.getElementById('brandCountry').value = country || '';
            document.getElementById('brandLogoFile').value = '';
            document.getElementById('brandDesc').value = desc || '';
            // Show existing logo preview
            if (logo) {
                document.getElementById('brandLogoPreview').src = logo;
                document.getElementById('brandLogoPreviewContainer').style.display = 'block';
            } else {
                document.getElementById('brandLogoPreviewContainer').style.display = 'none';
            }
            new bootstrap.Modal(document.getElementById('brandModal')).show();
        }

        function previewBrandLogo(input) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function (e) {
                    document.getElementById('brandLogoPreview').src = e.target.result;
                    document.getElementById('brandLogoPreviewContainer').style.display = 'block';
                };
                reader.readAsDataURL(input.files[0]);
            }
        }

        // Real-time: auto-reload brands on brand events
        async function reloadBrandsContent() {
            try {
                const response = await fetch(window.location.href);
                if (!response.ok) return;
                const html = await response.text();
                const doc = new DOMParser().parseFromString(html, 'text/html');
                const newGrid = doc.querySelector('.row.g-4');
                const currentGrid = document.querySelector('.row.g-4');
                if (newGrid && currentGrid) {
                    currentGrid.innerHTML = newGrid.innerHTML;
                }
            } catch (e) { console.error('[Brands] Refresh error:', e); }
        }

        window.__pageNotifHandlers = window.__pageNotifHandlers || [];
        window.__pageNotifHandlers.push(function(message, type) {
            if (type === 'brand') setTimeout(reloadBrandsContent, 500);
        });
    </script>
}
