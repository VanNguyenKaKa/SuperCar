@page
@model HyperCar.Web.Pages.Admin.OrdersModel
@{
    ViewData["Title"] = "Quản lý đơn hàng";
}

<section class="pt-5 mt-5">
    <div class="container-fluid py-4 px-4">
        <h2 class="section-title mb-4"><i class="fas fa-box me-2"></i>Quản lý <span class="text-accent">Đơn hàng</span></h2>

        <!-- Status Filter -->
        <div class="d-flex gap-2 mb-4 flex-wrap">
            <a href="?" class="btn btn-sm @(string.IsNullOrEmpty(Model.StatusFilter) ? "btn-accent" : "btn-outline-secondary")">Tất cả</a>
            <a href="/Admin/Orders?status=Pending" class="btn btn-sm @(Model.StatusFilter == "Pending" ? "btn-warning" : "btn-outline-warning")">Đang chờ</a>
            <a href="/Admin/Orders?status=Confirmed" class="btn btn-sm @(Model.StatusFilter == "Confirmed" ? "btn-info" : "btn-outline-info")">Đã xác nhận</a>
            <a href="/Admin/Orders?status=Shipping" class="btn btn-sm @(Model.StatusFilter == "Shipping" ? "btn-primary" : "btn-outline-primary")">Đang giao</a>
            <a href="/Admin/Orders?status=Delivered" class="btn btn-sm @(Model.StatusFilter == "Delivered" ? "btn-success" : "btn-outline-success")">Đã giao</a>
            <a href="/Admin/Orders?status=Completed" class="btn btn-sm @(Model.StatusFilter == "Completed" ? "btn-success" : "btn-outline-success")">Hoàn thành</a>
            <a href="/Admin/Orders?status=Cancelled" class="btn btn-sm @(Model.StatusFilter == "Cancelled" ? "btn-danger" : "btn-outline-danger")">Đã hủy</a>
        </div>

        <div class="table-responsive">
            <table class="table table-dark table-hover align-middle">
                <thead>
                    <tr>
                        <th>Mã ĐH</th>
                        <th>Khách hàng</th>
                        <th>Tổng</th>
                        <th>Sản phẩm</th>
                        <th>Trạng thái</th>
                        <th>Ngày</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Orders?.Items?.Any() == true)
                    {
                        @foreach (var order in Model.Orders.Items)
                        {
                            var badgeClass = order.StatusText switch
                            {
                                "Completed" => "bg-success",
                                "Cancelled" => "bg-danger",
                                "Pending" => "bg-warning text-dark",
                                "Confirmed" => "bg-info",
                                "Shipping" => "bg-primary",
                                "Delivered" => "bg-success",
                                _ => "bg-secondary"
                            };
                            <tr data-order-id="@order.Id">
                                <td><strong>#@order.Id</strong></td>
                                <td>
                                    <div>@order.UserName</div>
                                    <small class="text-muted">@order.UserEmail</small>
                                </td>
                                <td class="text-accent">$@order.TotalAmount.ToString("N0")</td>
                                <td>@order.Items?.Count</td>
                                <td><span class="badge @badgeClass admin-order-badge" data-order-id="@order.Id">@order.StatusDisplayText</span></td>
                                <td>@order.CreatedDate.ToString("MMM dd, yyyy")</td>
                                <td>
                                    @{
                                        var isLocked = order.StatusText == "Completed" || order.StatusText == "Cancelled" || order.StatusText == "Refunded";
                                        var nextStatuses = order.StatusText switch
                                        {
                                            "Pending" => new[] { ("Confirmed", "Đã xác nhận"), ("Cancelled", "Đã hủy") },
                                            "Confirmed" => new[] { ("Processing", "Đang xử lý"), ("Cancelled", "Đã hủy") },
                                            "Processing" => new[] { ("Shipping", "Đang giao"), ("Cancelled", "Đã hủy") },
                                            "Shipping" => new[] { ("Delivered", "Đã giao"), ("Cancelled", "Đã hủy") },
                                            "Delivered" => new[] { ("Completed", "Hoàn thành") },
                                            _ => Array.Empty<(string, string)>()
                                        };
                                    }
                                    @if (isLocked || !nextStatuses.Any())
                                    {
                                        <span class="badge bg-secondary"><i class="fas fa-lock me-1"></i>Đã khóa</span>
                                    }
                                    else
                                    {
                                        <div class="dropdown">
                                            <button class="btn btn-sm btn-outline-accent dropdown-toggle" data-bs-toggle="dropdown">
                                                Cập nhật trạng thái
                                            </button>
                                            <ul class="dropdown-menu dropdown-menu-dark">
                                                @foreach (var (val, label) in nextStatuses)
                                                {
                                                    <li>
                                                        <form method="post" asp-page-handler="UpdateStatus">
                                                            <input type="hidden" name="orderId" value="@order.Id" />
                                                            <input type="hidden" name="newStatus" value="@val" />
                                                            <button type="submit" class="dropdown-item">@label</button>
                                                        </form>
                                                    </li>
                                                }
                                            </ul>
                                        </div>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="7" class="text-center text-muted py-4">Không tìm thấy đơn hàng nào.</td></tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        @if (Model.Orders?.TotalPages > 1)
        {
            <nav>
                <ul class="pagination justify-content-center">
                    @for (int i = 1; i <= Model.Orders.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.Orders.PageNumber ? "active" : "")">
                            <a class="page-link" href="?page=@i&status=@Model.StatusFilter">@i</a>
                        </li>
                    }
                </ul>
            </nav>
        }
    </div>
</section>

@section Scripts {
    <script>
    (function() {
        // Real-time: auto-reload orders table when any order event occurs
        // Uses the global SignalR connection from site.js via window.__ordersNotifHandler

        async function reloadOrdersTable() {
            try {
                // Fetch current page HTML and replace the table body
                const currentUrl = window.location.href;
                const response = await fetch(currentUrl, { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
                if (!response.ok) return;

                const html = await response.text();
                const parser = new DOMParser();
                const doc = parser.parseFromString(html, 'text/html');

                // Replace tbody content
                const newTbody = doc.querySelector('tbody');
                const currentTbody = document.querySelector('tbody');
                if (newTbody && currentTbody) {
                    currentTbody.innerHTML = newTbody.innerHTML;
                    // Flash animation on the table
                    currentTbody.style.animation = 'none';
                    currentTbody.offsetHeight;
                    currentTbody.style.animation = 'tableFlash 0.5s ease';
                }

                console.log('[Orders] Table refreshed in real-time');
            } catch (err) {
                console.error('[Orders] Failed to refresh table:', err);
            }
        }

        // Register with global handler registry from site.js
        window.__pageNotifHandlers = window.__pageNotifHandlers || [];
        window.__pageNotifHandlers.push(function(message, type) {
            if (type === 'order' || type === 'payment') {
                setTimeout(reloadOrdersTable, 500);
            }
        });
    })();
    </script>

    <style>
        @@keyframes tableFlash {
            0% { background: rgba(255,107,53,0.1); }
            100% { background: transparent; }
        }
        @@keyframes badgePulse {
            0% { transform: scale(1); }
            30% { transform: scale(1.15); }
            60% { transform: scale(0.95); }
            100% { transform: scale(1); }
        }
    </style>
}
