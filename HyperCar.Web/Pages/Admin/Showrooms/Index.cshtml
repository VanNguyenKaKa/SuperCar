@page
@model HyperCar.Web.Pages.Admin.Showrooms.IndexModel
@{
    ViewData["Title"] = "Quản lý Showroom";
}

<section class="pt-5 mt-5">
    <div class="container py-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold"><i class="fas fa-building me-2 text-accent"></i>Quản lý Showroom</h2>
            <a href="/Admin/Dashboard" class="btn btn-outline-light"><i class="fas fa-arrow-left me-2"></i>Quay lại</a>
        </div>

        @if (!string.IsNullOrEmpty(Model.SuccessMessage))
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="fas fa-check-circle me-2"></i>@Model.SuccessMessage
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="fas fa-exclamation-circle me-2"></i>@Model.ErrorMessage
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @* ═══ Add Showroom ═══ *@
        <div class="card bg-dark border-secondary mb-4">
            <div class="card-header border-secondary">
                <h5 class="mb-0"><i class="fas fa-plus-circle me-2 text-accent"></i>Thêm Showroom mới</h5>
            </div>
            <div class="card-body">
                <form method="post" asp-page-handler="Add">
                    <div class="row g-3 align-items-end">
                        <div class="col-md-4">
                            <label class="form-label">Tên Showroom <span class="text-danger">*</span></label>
                            <input asp-for="ShowroomName" class="form-control bg-dark text-light border-secondary"
                                   placeholder="VD: HyperCar Quận 1" required />
                        </div>
                        <div class="col-md-5">
                            <label class="form-label">Địa chỉ</label>
                            <input asp-for="ShowroomAddress" class="form-control bg-dark text-light border-secondary"
                                   placeholder="VD: 123 Nguyễn Huệ, Q.1, TP.HCM" />
                        </div>
                        <div class="col-md-3">
                            <button type="submit" class="btn btn-accent w-100">
                                <i class="fas fa-plus me-2"></i>Thêm
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        @* ═══ Showroom List ═══ *@
        <div class="card bg-dark border-secondary">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-dark table-hover mb-0">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Tên Showroom</th>
                                <th>Địa chỉ</th>
                                <th>Trạng thái</th>
                                <th class="text-center">Hành động</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!Model.ShowroomList.Any())
                            {
                                <tr>
                                    <td colspan="5" class="text-center text-muted py-4">Chưa có showroom nào.</td>
                                </tr>
                            }
                            @foreach (var sr in Model.ShowroomList)
                            {
                                <tr>
                                    <td>@sr.Id</td>
                                    <td>@sr.Name</td>
                                    <td>@(sr.Address ?? "—")</td>
                                    <td>
                                        @if (sr.IsActive)
                                        {
                                            <span class="badge bg-success">Hoạt động</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Vô hiệu</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <button type="button" class="btn btn-sm btn-outline-info"
                                                data-bs-toggle="modal" data-bs-target="#editModal-@sr.Id" title="Sửa">
                                            <i class="fas fa-edit"></i>
                                        </button>

                                        <form method="post" asp-page-handler="Toggle" class="d-inline">
                                            <input type="hidden" name="id" value="@sr.Id" />
                                            <button type="submit" class="btn btn-sm @(sr.IsActive ? "btn-outline-warning" : "btn-outline-success")"
                                                    title="@(sr.IsActive ? "Vô hiệu hoá" : "Kích hoạt")">
                                                <i class="fas @(sr.IsActive ? "fa-eye-slash" : "fa-eye")"></i>
                                            </button>
                                        </form>

                                        <form method="post" asp-page-handler="Delete" class="d-inline"
                                              onsubmit="return confirm('Xóa showroom này?');">
                                            <input type="hidden" name="id" value="@sr.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Xóa">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>

                                @* Edit Modal *@
                                <div class="modal fade" id="editModal-@sr.Id" tabindex="-1">
                                    <div class="modal-dialog">
                                        <div class="modal-content bg-dark">
                                            <form method="post" asp-page-handler="Edit">
                                                <div class="modal-header border-secondary">
                                                    <h5 class="modal-title"><i class="fas fa-edit me-2 text-accent"></i>Sửa Showroom</h5>
                                                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                                                </div>
                                                <div class="modal-body">
                                                    <input type="hidden" name="id" value="@sr.Id" />
                                                    <div class="mb-3">
                                                        <label class="form-label">Tên Showroom</label>
                                                        <input type="text" name="name" value="@sr.Name"
                                                               class="form-control bg-dark text-light border-secondary" required />
                                                    </div>
                                                    <div class="mb-3">
                                                        <label class="form-label">Địa chỉ</label>
                                                        <input type="text" name="address" value="@sr.Address"
                                                               class="form-control bg-dark text-light border-secondary"
                                                               placeholder="Chưa có" />
                                                    </div>
                                                </div>
                                                <div class="modal-footer border-secondary">
                                                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Hủy</button>
                                                    <button type="submit" class="btn btn-accent">
                                                        <i class="fas fa-save me-2"></i>Lưu
                                                    </button>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</section>
