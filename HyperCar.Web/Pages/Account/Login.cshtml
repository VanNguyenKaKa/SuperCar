@page
@model HyperCar.Web.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Đăng nhập";
    Layout = "_Layout";
}

<section class="pt-5 mt-5">
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-md-5">
                <div class="card bg-dark border-secondary">
                    <div class="card-body p-4">
                        <h3 class="text-center mb-4"><i class="fas fa-car-side text-accent me-2"></i>Chào mừng trở lại</h3>
                        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                        {
                            <div class="alert alert-danger">@Model.ErrorMessage</div>
                        }
                        <form method="post">
                            <div class="mb-3">
                                <label class="form-label">Email</label>
                                <input type="email" name="Email" class="form-control" required value="@Model.Email" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Password</label>
                                <input type="password" name="Password" class="form-control" required />
                            </div>
                            <div class="mb-3 form-check">
                                <input type="checkbox" name="RememberMe" class="form-check-input" id="remember" />
                                <label class="form-check-label" for="remember">Ghi nhớ đăng nhập</label>
                            </div>
                            <button type="submit" class="btn btn-accent w-100 btn-lg">
                                <i class="fas fa-sign-in-alt me-2"></i>Đăng nhập
                            </button>
                        </form>
                        <p class="text-center mt-3 mb-0">
                            Chưa có tài khoản? <a href="/Account/Register" class="text-accent">Đăng ký ngay</a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
