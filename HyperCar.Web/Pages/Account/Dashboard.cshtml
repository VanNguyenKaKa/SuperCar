@page
@model HyperCar.Web.Pages.Account.DashboardModel
@{
    ViewData["Title"] = "My Dashboard";
}

<section class="pt-5 mt-5">
    <div class="container py-4">
        <h2 class="section-title mb-4"><i class="fas fa-tachometer-alt me-2"></i>My <span class="text-accent">Dashboard</span></h2>

        <!-- Stats Cards -->
        <div class="row g-4 mb-4">
            <div class="col-md-3">
                <div class="stat-card" style="border-left: 4px solid #ff6b35;">
                    <h3 id="statTotalOrders" class="text-accent mb-0">@(Model.Orders?.Count() ?? 0)</h3>
                    <small class="text-muted">Total Orders</small>
                </div>
            </div>
            <div class="col-md-3">
                <div class="stat-card" style="border-left: 4px solid #198754;">
                    <h3 id="statCompleted" class="text-success mb-0">@(Model.Orders?.Count(o => o.StatusText == "Completed") ?? 0)</h3>
                    <small class="text-muted">Completed</small>
                </div>
            </div>
            <div class="col-md-3">
                <div class="stat-card" style="border-left: 4px solid #ffc107;">
                    <h3 id="statInProgress" class="text-warning mb-0">@(Model.Orders?.Count(o => o.StatusText == "Pending" || o.StatusText == "Confirmed" || o.StatusText == "Shipping") ?? 0)</h3>
                    <small class="text-muted">In Progress</small>
                </div>
            </div>
            <div class="col-md-3">
                <div class="stat-card" style="border-left: 4px solid #0dcaf0;">
                    <h3 id="statTotalSpent" class="text-info mb-0">$@(Model.Orders?.Where(o => o.Payment?.StatusText == "Paid").Sum(o => o.TotalAmount).ToString("N0") ?? "0")</h3>
                    <small class="text-muted">Total Spent</small>
                </div>
            </div>
        </div>

        <!-- Order History -->
        <div class="card bg-dark border-secondary">
            <div class="card-header border-secondary d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="fas fa-history me-2 text-accent"></i>Order History</h5>
                <a href="/Cars" class="btn btn-sm btn-accent"><i class="fas fa-shopping-cart me-1"></i>Shop Now</a>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-dark table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Order #</th>
                                <th>Date</th>
                                <th>Items</th>
                                <th>Total</th>
                                <th>Status</th>
                                <th>Payment</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Orders?.Any() == true)
                            {
                                @foreach (var order in Model.Orders)
                                {
                                    var badgeClass = order.StatusText switch
                                    {
                                        "Completed" => "bg-success",
                                        "Cancelled" => "bg-danger",
                                        "Pending" => "bg-warning text-dark",
                                        "Confirmed" => "bg-info",
                                        "Shipping" => "bg-primary",
                                        "Delivered" => "bg-success",
                                        _ => "bg-secondary"
                                    };
                                    var payBadge = order.Payment?.StatusText switch
                                    {
                                        "Paid" => "bg-success",
                                        "Failed" => "bg-danger",
                                        _ => "bg-warning text-dark"
                                    };
                                    <tr data-order-id="@order.Id">
                                        <td><strong>#@order.Id</strong></td>
                                        <td>@order.CreatedDate.ToString("MMM dd, yyyy")</td>
                                        <td>
                                            @if (order.Items?.Any() == true)
                                            {
                                                @foreach (var item in order.Items.Take(2))
                                                {
                                                    <div class="small">@item.CarName x@item.Quantity</div>
                                                }
                                                @if (order.Items.Count > 2)
                                                {
                                                    <small class="text-muted">+@(order.Items.Count - 2) more</small>
                                                }
                                            }
                                        </td>
                                        <td class="text-accent fw-bold">$@order.TotalAmount.ToString("N0")</td>
                                        <td><span class="badge @badgeClass order-status-badge" data-order-id="@order.Id">@order.StatusText</span></td>
                                        <td><span class="badge @payBadge payment-status-badge" data-order-id="@order.Id">@(order.Payment?.StatusText ?? "Pending")</span></td>
                                        <td>
                                            <a href="/Account/OrderDetail?id=@order.Id" class="btn btn-outline-accent btn-sm"><i class="fas fa-eye"></i></a>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="7" class="text-center py-5">
                                        <i class="fas fa-shopping-bag fa-3x text-muted mb-3"></i>
                                        <p class="text-muted">You haven't placed any orders yet.</p>
                                        <a href="/Cars" class="btn btn-accent"><i class="fas fa-car me-1"></i>Browse Collection</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        // Real-time Customer Dashboard — uses global SignalR from site.js

        // Refresh customer stats via AJAX
        async function refreshCustomerStats() {
            try {
                const response = await fetch('/Account/Dashboard?handler=Stats');
                if (!response.ok) return;
                const stats = await response.json();

                const statTotalOrders = document.getElementById('statTotalOrders');
                const statCompleted = document.getElementById('statCompleted');
                const statInProgress = document.getElementById('statInProgress');
                const statTotalSpent = document.getElementById('statTotalSpent');

                if (statTotalOrders) statTotalOrders.textContent = stats.totalOrders;
                if (statCompleted) statCompleted.textContent = stats.completed;
                if (statInProgress) statInProgress.textContent = stats.inProgress;
                if (statTotalSpent) statTotalSpent.textContent = '$' + stats.totalSpent.toLocaleString('en-US');

                console.log('[Customer Dashboard] Stats refreshed');
            } catch (e) { console.error('[Customer Dashboard] Refresh error:', e); }
        }

        // Auto-reload orders table
        async function reloadCustomerOrders() {
            try {
                const response = await fetch(window.location.href);
                if (!response.ok) return;
                const html = await response.text();
                const doc = new DOMParser().parseFromString(html, 'text/html');
                const newTbody = doc.querySelector('tbody');
                const currentTbody = document.querySelector('tbody');
                if (newTbody && currentTbody) {
                    currentTbody.innerHTML = newTbody.innerHTML;
                    currentTbody.style.animation = 'none';
                    currentTbody.offsetHeight;
                    currentTbody.style.animation = 'tableFlash 0.5s ease';
                }
            } catch (e) { console.error('[Customer Dashboard] Table refresh error:', e); }
        }

        // Register with global handler registry
        window.__pageNotifHandlers = window.__pageNotifHandlers || [];
        window.__pageNotifHandlers.push(function(message, type) {
            if (type === 'order' || type === 'payment' || type === 'danger') {
                setTimeout(function() {
                    refreshCustomerStats();
                    reloadCustomerOrders();
                }, 500);
            }
        });
    </script>

    <style>
        @@keyframes tableFlash {
            0% { background: rgba(255,107,53,0.1); }
            100% { background: transparent; }
        }
        @@keyframes badgePulse {
            0% { transform: scale(1); }
            30% { transform: scale(1.15); }
            60% { transform: scale(0.95); }
            100% { transform: scale(1); }
        }
    </style>
}
