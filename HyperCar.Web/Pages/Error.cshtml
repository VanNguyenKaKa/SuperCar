@page
@model HyperCar.Web.Pages.ErrorModel
@{
    ViewData["Title"] = "Lỗi";
}

<section class="pt-5 mt-5">
    <div class="container py-5 text-center">
        <i class="fas fa-exclamation-triangle fa-5x text-warning mb-4"></i>
        <h1 class="display-4">Ôi!</h1>
        <p class="lead text-muted">Đã xảy ra lỗi khi xử lý yêu cầu của bạn.</p>
        @if (Model.ShowRequestId)
        {
            <p class="text-muted"><strong>Mã yêu cầu:</strong> <code>@Model.RequestId</code></p>
        }
        <a href="/" class="btn btn-accent btn-lg mt-3"><i class="fas fa-home me-2"></i>Về trang chủ</a>
    </div>
</section>
